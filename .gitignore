# Игнорировать системные файлы
.DS_Store
Thumbs.db
desktop.ini

# Игнорировать логи и временные файлы
*.log
error_log
logs/
temp/
tmp/

# Игнорировать резервные и скрытые файлы редакторов
*~
*.bak
*.swp
*.swo
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Игнорировать зависимости (если используются)
node_modules/
vendor/

# Игнорировать конфигурации локальной среды
.env
.env.local
.env.*.local

# Игнорировать папки с кэшем
cache/
.cache/

# Игнорировать автозагружаемые файлы Composer (если используется)
composer.phar
.php-cs-fixer.cache

# Игнорировать папку с загрузками (если не нужна в репозитории)
/uploads/
/public/uploads/

# Игнорировать дампы баз данных
*.sql
*.sqlite
*.db

# Игнорировать артефакты сборки (если есть)
/dist/
/build/
/out/
/public/build/

# Игнорировать папку с сессиями PHP
/sessions/

# Игнорировать файлы отладки Xdebug или других профилировщиков
xdebug_*.log